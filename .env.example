# ─────────────────────────────────────────────────────────────────
# AuraOps Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# Anthropic Claude API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# GitLab personal access token — Settings → Access Tokens → api scope
GITLAB_TOKEN=glpat-YOUR_TOKEN_HERE

# GitLab instance URL (default: gitlab.com)
GITLAB_URL=https://gitlab.com

# Google Cloud Project ID (leave blank for mock deployments)
GCP_PROJECT_ID=

# Preferred deployment region (low-carbon default)
DEPLOY_REGION=europe-north1

# Path to persist MR processing history
HISTORY_FILE=/tmp/auraops_history.json

# Server port
PORT=8080
