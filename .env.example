ANTHROPIC_API_KEY=sk-ant-api03...                 # Get from console.anthropic.com
GITLAB_TOKEN=glpat-...                              # GitLab Personal Access Token (API scope)
GITLAB_URL=https://gitlab.com                       # Your GitLab instance URL
GCP_PROJECT_ID=your-gcp-project-123                 # Your Google Cloud Project ID
DEPLOY_REGION=europe-north1                         # e.g. europe-north1
HISTORY_FILE=/tmp/auraops_history.json              # Path to store MR history
PORT=8080                                           # Port for the web server
